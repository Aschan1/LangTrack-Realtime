    "\n",
    "model_id = \"openai/whisper-tiny\"\n",
    "\n",
    "model = AutoModelForSpeechSeq2Seq.from_pretrained(\n",
    "    model_id, torch_dtype=torch_dtype, low_cpu_mem_usage=True, use_safetensors=True\n",
    ")\n",
    "model.to(device)\n",
    "\n",
    "processor = AutoProcessor.from_pretrained(model_id)\n",
    "device_for_pipeline = 0 if torch.cuda.is_available() else -1\n",
    "pipe = pipeline(\n",
    "    \"automatic-speech-recognition\",\n",
    "    model=model,\n",
    "    tokenizer=processor.tokenizer,\n",
    "    feature_extractor=processor.feature_extractor,\n",
    "    torch_dtype=torch_dtype,\n",
    "    device=device_for_pipeline,\n",
    ")\n",
    "\n",
    "from datasets import Audio\n",
    "import io\n",
    "\n",
    "dataset = load_dataset(\"distil-whisper/librispeech_long\", \"clean\", split=\"validation\", streaming=True)\n",
    "dataset = dataset.cast_column(\"audio\", Audio(decode=False))\n",
    "batch_size = 8 if torch.cuda.is_available() else 1\n",
    "\n",
    "def _to_audio_array(audio_sample):\n",
    "    if isinstance(audio_sample, dict) and audio_sample.get(\"bytes\") is not None:\n",
    "        audio_input, _sample_rate = so.read(io.BytesIO(audio_sample[\"bytes\"]), dtype=\"float32\")\n",
    "        return audio_input\n",
    "    if isinstance(audio_sample, dict) and audio_sample.get(\"path\"):\n",
    "        audio_input, _sample_rate = so.read(audio_sample[\"path\"], dtype=\"float32\")\n",
    "        return audio_input\n",
    "    if isinstance(audio_sample, dict) and \"array\" in audio_sample:\n",
    "        return audio_sample[\"array\"]\n",
    "    return audio_sample\n",
    "\n",
    "audio_batch = []\n",
    "for sample in dataset.take(batch_size):\n",
    "    audio_batch.append(_to_audio_array(sample[\"audio\"]))\n",
    "\n",
    "def _dataset_audio_iter(ds):\n",
    "    for audio in KeyDataset(ds, \"audio\"):\n",
    "        yield np.asarray(audio, dtype=np.float32)\n",
    "\n",
    "batch_dataset = Dataset.from_dict({\"audio\": audio_batch})\n",
    "for idx, result in enumerate(pipe(_dataset_audio_iter(batch_dataset), return_timestamps=True, batch_size=batch_size)):\n",
    "    print(f\"[sample {idx}] {result['text']}\")"
